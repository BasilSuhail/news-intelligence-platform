        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "better-sqlite3": "^9.2.2",
        "@xenova/transformers": "^2.10.0",
        "natural": "^6.10.0",
        "ml-kmeans": "^6.0.0",
        "compromise": "^14.10.0",
        "@google/generative-ai": "^0.1.3",
        "axios": "^1.6.2"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/better-sqlite3": "^7.6.8",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
