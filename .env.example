# News API Keys
NEWSAPI_KEY=your_newsapi_key_here

# Gemini API Keys (comma-separated for rotation and load balancing)
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2,your_gemini_key_3

# Finnhub API (for market data backtesting)
FINNHUB_API_KEY=your_finnhub_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_PATH=news-data/intelligence.db
